---
import { site } from "../config";
---

<section class="section" id="about">
  <div
    class="grid items-start gap-8 lg:grid-cols-[minmax(220px,300px)_minmax(0,1fr)] lg:gap-16"
    data-reveal-group
  >
    <div data-reveal>
      <!-- PLACEHOLDER: replace this block with your photo, e.g.
           <img class="block w-full rounded-[14px]" src="/images/jordan.jpg" alt="Jordan Frias-Metcalfe adjusting a patient" />
           (put the file in the public/ folder) -->
      <div
        class="relative aspect-[5/6] overflow-hidden rounded-[14px] border border-sage-line bg-white max-lg:max-w-[260px]"
        role="img"
        aria-label="Portrait of the doctor"
      >
        <svg class="block h-full w-full" viewBox="0 0 200 240" aria-hidden="true">
          <circle cx="100" cy="82" r="44" fill="var(--color-sage)"></circle>
          <path d="M30 240 C30 178, 170 178, 170 240 Z" fill="var(--color-sage)"></path>
        </svg>
        <span class="absolute inset-x-0 bottom-3 text-center text-[0.85rem] text-moss">
          Your photo here
        </span>
      </div>
    </div>
    <div data-reveal>
      <p class="eyebrow">About your chiropractor</p>
      <h2>{site.doctorName}</h2>
      <p>
        I opened {site.practiceName} because I kept meeting people who had
        decided that pain was just part of getting older, sitting at a desk, or
        picking up their kids. It usually isn't.
      </p>
      <p>
        I've spent over a decade treating spines — weekend athletes, new
        parents, nurses on twelve-hour shifts — and the goal is always the
        same: find the cause, fix what we can fix, and teach you how to keep it
        that way.
        <!-- PLACEHOLDER: your own story -->
      </p>
      <ul class="m-0 mt-6 list-none p-0">
        {
          site.credentials.map((cred) => (
            <li class="border-t border-sage-line py-2 font-medium">{cred}</li>
          ))
        }
      </ul>
    </div>
  </div>
  <blockquote class="mx-auto mb-0 mt-12 max-w-[42rem] text-center md:mt-20" data-reveal>
    <p class="mx-auto mb-3 font-display text-[clamp(1.25rem,2.6vw,1.6rem)] leading-[1.4]">
      “I walked in sideways and walked out standing straight. Three visits
      later I was back in the garden. I should have come years ago.”
    </p>
    <cite class="not-italic text-moss">
      — Maria T., patient since 2023 <!-- PLACEHOLDER: real testimonial -->
    </cite>
  </blockquote>
</section>
