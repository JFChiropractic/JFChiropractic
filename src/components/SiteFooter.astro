---
import { site } from "../config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>© {year} {site.practiceName} · {site.address.join(", ")}</p>
  <p class="footer-fineprint">
    This website is for general information and isn't medical advice. For
    emergencies, call your local emergency number.
  </p>
</footer>

<style>
  .site-footer {
    padding: 2rem var(--pad-x) 2.5rem;
    border-top: 1px solid var(--sage-line);
    font-size: 0.9rem;
    color: #4a5d55;
  }
  .site-footer p {
    margin-bottom: 0.4rem;
  }
  .footer-fineprint {
    font-size: 0.8rem;
  }
</style>
