---
// Signature element: a vertebra rail that tracks scroll position (desktop only).
const sections = [
  { id: "top", label: "Top" },
  { id: "care", label: "Care" },
  { id: "first-visit", label: "First visit" },
  { id: "about", label: "About" },
  { id: "visit", label: "Visit" },
  { id: "book", label: "Book" },
] as const;
---

<nav
  class="fixed left-6 top-1/2 z-[15] hidden -translate-y-1/2 flex-col gap-[1.1rem] before:absolute before:bottom-2 before:left-1.5 before:top-2 before:w-0.5 before:rounded before:bg-sage-line before:content-[''] xl:flex"
  aria-label="Page sections"
>
  {
    sections.map((s) => (
      <a class="group relative flex items-center gap-3 no-underline" href={`#${s.id}`} data-section={s.id}>
        <span
          class="h-2.5 w-3.5 rounded-[5px] bg-sage-line transition-all duration-200 group-data-[active]:scale-x-125 group-data-[active]:bg-amber motion-reduce:transition-none"
        />
        <span
          class="-translate-x-1 text-[0.72rem] font-bold uppercase tracking-[0.08em] text-spruce opacity-0 transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:translate-x-0 group-focus-visible:opacity-100 group-data-[active]:translate-x-0 group-data-[active]:opacity-100 motion-reduce:transition-none"
        >
          {s.label}
        </span>
      </a>
    ))
  }
</nav>

<script>
  // Highlight the vertebra for the section currently in view.
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-section]");

  if (links.length && "IntersectionObserver" in window) {
    const byId = new Map<string, HTMLAnchorElement>();
    links.forEach((link) => {
      if (link.dataset.section) byId.set(link.dataset.section, link);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          links.forEach((l) => delete l.dataset.active);
          const active = byId.get(entry.target.id);
          if (active) active.dataset.active = "";
        }
      },
      { rootMargin: "-40% 0px -50% 0px" }
    );

    byId.forEach((_link, id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }
</script>
