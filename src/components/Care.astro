---
import { services } from "../data/services";
---

<section class="section" id="care">
  <div class="section-head" data-reveal>
    <p class="eyebrow">What we treat</p>
    <h2>Care for the whole kinetic chain</h2>
    <p class="section-lede">
      Every plan starts with an exam and ends with you moving better. These are
      the ways we get you there.
    </p>
  </div>
  <ul
    class="m-0 grid list-none grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-5 p-0"
    data-reveal-group
  >
    {
      services.map((service) => (
        <li
          class="rounded-[14px] border border-sage-line bg-white px-6 pb-5 pt-6 transition-shadow duration-300 hover:shadow-[0_10px_30px_rgba(28,43,38,0.08)]"
          data-reveal
        >
          <svg
            class="mb-4 h-[34px] w-[34px] fill-amber stroke-amber"
            viewBox="0 0 40 40"
            aria-hidden="true"
            set:html={service.icon}
          />
          <h3>{service.title}</h3>
          <p class="m-0 text-[0.98rem]">{service.description}</p>
        </li>
      ))
    }
  </ul>
</section>
