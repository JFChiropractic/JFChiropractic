---
import { site } from "../config";
---

<header class="site-header">
  <a class="wordmark" href="#top">
    <svg class="wordmark-glyph" viewBox="0 0 32 32" aria-hidden="true">
      <rect width="32" height="32" rx="7" fill="var(--spruce)"></rect>
      <circle cx="16" cy="8" r="2.6" fill="var(--paper)"></circle>
      <circle cx="16" cy="16" r="2.6" fill="var(--amber)"></circle>
      <circle cx="16" cy="24" r="2.6" fill="var(--paper)"></circle>
    </svg>
    {site.practiceName}
  </a>
  <nav class="site-nav" id="site-nav" aria-label="Main">
    <a href="#care">Care</a>
    <a href="#first-visit">First visit</a>
    <a href="#about">About</a>
    <a href="#visit">Hours &amp; location</a>
  </nav>
  <a class="button button-amber header-cta" href="#book">Book a visit</a>
  <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav">
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
    Menu
  </button>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0.9rem var(--pad-x);
    background: var(--paper-soft);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--sage-line);
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--ink);
    text-decoration: none;
    margin-right: auto;
    white-space: nowrap;
  }
  .wordmark-glyph {
    width: 30px;
    height: 30px;
    flex: none;
  }

  .site-nav {
    display: flex;
    gap: 1.6rem;
  }
  .site-nav a {
    color: var(--ink);
    text-decoration: none;
    font-weight: 500;
  }
  .site-nav a:hover {
    color: var(--spruce);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .nav-toggle {
    display: none;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: 2px solid var(--sage-line);
    border-radius: 999px;
    padding: 0.45rem 1rem;
    font: inherit;
    font-weight: 700;
    color: var(--ink);
    cursor: pointer;
  }
  .nav-toggle-bar {
    display: block;
    width: 16px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
  }
  .nav-toggle-bar + .nav-toggle-bar {
    margin-top: -6px;
    transform: translateY(4px);
  }

  @media (max-width: 720px) {
    .site-header {
      flex-wrap: wrap;
      gap: 0.8rem 1rem;
    }
    .header-cta {
      order: 2;
      margin-left: auto;
    }
    .nav-toggle {
      display: inline-flex;
      order: 3;
    }
    .site-nav {
      order: 4;
      flex-basis: 100%;
      flex-direction: column;
      gap: 0.2rem;
      display: none;
      padding-bottom: 0.4rem;
    }
    .site-nav.open {
      display: flex;
    }
    .site-nav a {
      padding: 0.5rem 0;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const nav = document.getElementById("site-nav");

  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const open = nav.classList.toggle("open");
      toggle.setAttribute("aria-expanded", String(open));
    });
    nav.addEventListener("click", (e) => {
      if (e.target instanceof HTMLAnchorElement) {
        nav.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }
</script>
