---
import { site } from "../config";

const year = new Date().getFullYear();
---

<footer class="border-t border-sage-line px-pad pb-10 pt-8 text-sm text-moss xl:px-32">
  <p class="mb-1.5">© {year} {site.practiceName} · {site.address.join(", ")}</p>
  <p class="mb-0 text-xs">
    This website is for general information and isn't medical advice. For
    emergencies, call your local emergency number.
  </p>
</footer>
