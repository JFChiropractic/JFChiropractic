---
import { site } from "../config";
---

<header
  class="sticky top-0 z-20 flex items-center gap-4 border-b border-sage-line bg-paper/70 px-pad py-3.5 backdrop-blur-md max-md:flex-wrap md:gap-8 xl:px-32"
>
  <a
    class="mr-auto flex items-center gap-2.5 whitespace-nowrap font-display text-[1.15rem] text-ink no-underline"
    href="#top"
  >
    <svg class="h-[30px] w-[30px] flex-none" viewBox="0 0 32 32" aria-hidden="true">
      <rect width="32" height="32" rx="7" fill="var(--color-spruce)"></rect>
      <circle cx="16" cy="8" r="2.6" fill="var(--color-paper)"></circle>
      <circle cx="16" cy="16" r="2.6" fill="var(--color-amber)"></circle>
      <circle cx="16" cy="24" r="2.6" fill="var(--color-paper)"></circle>
    </svg>
    {site.practiceName}
  </a>
  <nav
    class="flex gap-6 max-md:order-4 max-md:hidden max-md:basis-full max-md:flex-col max-md:gap-1 max-md:pb-2"
    id="site-nav"
    aria-label="Main"
  >
    <a class="nav-link" href="#care">Care</a>
    <a class="nav-link" href="#first-visit">First visit</a>
    <a class="nav-link" href="#about">About</a>
    <a class="nav-link" href="#visit">Hours &amp; location</a>
  </nav>
  <a class="button button-amber max-md:order-2" href="#book">Book a visit</a>
  <button
    class="hidden cursor-pointer items-center gap-2 rounded-full border-2 border-sage-line bg-transparent px-4 py-2 font-bold text-ink max-md:order-3 max-md:inline-flex"
    aria-expanded="false"
    aria-controls="site-nav"
    id="nav-toggle"
  >
    <span class="flex flex-col gap-1" aria-hidden="true">
      <span class="h-0.5 w-4 rounded bg-ink"></span>
      <span class="h-0.5 w-4 rounded bg-ink"></span>
    </span>
    Menu
  </button>
</header>

<style>
  @reference "../styles/global.css";

  .nav-link {
    @apply font-medium text-ink no-underline hover:text-spruce hover:underline hover:underline-offset-4 max-md:py-2;
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const nav = document.getElementById("site-nav");

  if (toggle && nav) {
    const setOpen = (open: boolean) => {
      nav.classList.toggle("max-md:hidden", !open);
      toggle.setAttribute("aria-expanded", String(open));
    };
    toggle.addEventListener("click", () => {
      setOpen(nav.classList.contains("max-md:hidden"));
    });
    nav.addEventListener("click", (e) => {
      if (e.target instanceof HTMLAnchorElement) setOpen(false);
    });
  }
</script>
