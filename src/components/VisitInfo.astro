---
import { site } from "../config";
---

<section class="section bg-sage" id="visit">
  <div class="section-head" data-reveal>
    <p class="eyebrow">Hours &amp; location</p>
    <h2>Easy to reach, easy to park</h2>
  </div>
  <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-8" data-reveal-group>
    <div data-reveal>
      <h3>Find us</h3>
      <p>
        {site.address.map((line, i) => (
          <>
            {i > 0 && <br />}
            {line}
          </>
        ))}
      </p>
      <p class="mb-0"><a href={site.mapsUrl} class="text-link">Open in Google Maps</a></p>
    </div>
    <div data-reveal>
      <h3>Hours</h3>
      <table class="border-collapse">
        <tbody>
          {
            site.openingHours.map((row) => (
              <tr>
                <th class="py-1 pr-8 text-left font-bold" scope="row">{row.days}</th>
                <td class="py-1">{row.hours}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <div data-reveal>
      <h3>Good to know</h3>
      <ul class="m-0 list-none p-0">
        {site.goodToKnow.map((item) => <li class="py-1">{item}</li>)}
      </ul>
    </div>
  </div>
</section>
