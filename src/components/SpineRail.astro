---
// Signature element: a vertebra rail that tracks scroll position (desktop only).
const sections = [
  { id: "top", label: "Top" },
  { id: "care", label: "Care" },
  { id: "first-visit", label: "First visit" },
  { id: "about", label: "About" },
  { id: "visit", label: "Visit" },
  { id: "book", label: "Book" },
] as const;
---

<nav class="spine-rail" aria-label="Page sections">
  {
    sections.map((s) => (
      <a href={`#${s.id}`} data-section={s.id}>
        <span class="rail-dot" />
        <span class="rail-label">{s.label}</span>
      </a>
    ))
  }
</nav>

<style>
  .spine-rail {
    position: fixed;
    left: 1.4rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 15;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .spine-rail::before {
    content: "";
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--sage-line);
    border-radius: 2px;
  }
  .spine-rail a {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }
  .rail-dot {
    width: 14px;
    height: 10px;
    border-radius: 5px;
    background: var(--sage-line);
    transition: background-color 160ms ease, transform 160ms ease;
  }
  .rail-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--spruce);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 160ms ease, transform 160ms ease;
  }
  .spine-rail a:hover .rail-label,
  .spine-rail a:focus-visible .rail-label,
  .spine-rail a.active .rail-label {
    opacity: 1;
    transform: none;
  }
  .spine-rail a.active .rail-dot {
    background: var(--amber);
    transform: scaleX(1.25);
  }

  @media (max-width: 1180px) {
    .spine-rail {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail-dot,
    .rail-label {
      transition: none;
    }
  }
</style>

<script>
  // Highlight the vertebra for the section currently in view.
  const links = document.querySelectorAll<HTMLAnchorElement>(".spine-rail a");

  if (links.length && "IntersectionObserver" in window) {
    const byId = new Map<string, HTMLAnchorElement>();
    links.forEach((link) => {
      if (link.dataset.section) byId.set(link.dataset.section, link);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          links.forEach((l) => l.classList.remove("active"));
          byId.get(entry.target.id)?.classList.add("active");
        }
      },
      { rootMargin: "-40% 0px -50% 0px" }
    );

    byId.forEach((_link, id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }
</script>
