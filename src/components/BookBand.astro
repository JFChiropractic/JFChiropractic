---
import { site } from "../config";
---

<section class="section bg-spruce-deep text-center text-paper" id="book" data-reveal-group>
  <h2 class="mx-auto max-w-[26ch]" data-reveal>
    Your back has carried you this far.<br />Time to return the favor.
  </h2>
  <div class="mb-5 mt-8 flex flex-wrap justify-center gap-4" data-reveal>
    <a class="button button-amber" href={`tel:${site.phone}`}>Call {site.phoneDisplay}</a>
    <a class="button button-ghost-light" href={`mailto:${site.email}`}>Email us</a>
    <!-- If you use an online booking service (Jane, Calendly, etc.),
         swap one of these for that link. -->
  </div>
  <p class="mx-auto mb-0 text-[0.95rem] text-sage-mist" data-reveal>
    Same-week appointments are usually available.
  </p>
</section>
