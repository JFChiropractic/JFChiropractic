---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SpineRail from "../components/SpineRail.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const favicon =
  "data:image/svg+xml," +
  encodeURIComponent(
    `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='7' fill='#204A3F'/><circle cx='16' cy='8' r='2.6' fill='#F3F6F2'/><circle cx='16' cy='16' r='2.6' fill='#D08C2E'/><circle cx='16' cy='24' r='2.6' fill='#F3F6F2'/></svg>`
  );
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={favicon} />
    <!-- Marks JS as available before first paint so Motion can hide-then-reveal
         without a flash; without JS the page renders fully visible. -->
    <script is:inline>document.documentElement.classList.add("js");</script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Young+Serif&family=Karla:ital,wght@0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <SiteHeader />
    <SpineRail />
    <main id="top">
      <slot />
    </main>
    <SiteFooter />

    <script>
      // Scroll-triggered reveals, powered by Motion (motion.dev).
      // [data-reveal-group] staggers its [data-reveal] children into view;
      // standalone [data-reveal] elements rise in on their own.
      import { animate, inView, stagger } from "motion";

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const EASE_OUT: [number, number, number, number] = [0.22, 1, 0.36, 1];

      function revealOnEnter(trigger: Element, targets: Element[]) {
        const stop = inView(
          trigger,
          () => {
            animate(
              targets,
              { opacity: [0, 1], y: [18, 0] },
              { duration: 0.65, delay: stagger(0.09), ease: EASE_OUT }
            );
            stop();
          },
          { margin: "0px 0px -12% 0px" }
        );
      }

      if (!reduceMotion) {
        const grouped = new Set<Element>();
        document.querySelectorAll("[data-reveal-group]").forEach((group) => {
          const items = [...group.querySelectorAll("[data-reveal]")];
          items.forEach((el) => grouped.add(el));
          if (items.length) revealOnEnter(group, items);
        });
        document.querySelectorAll("[data-reveal]").forEach((el) => {
          if (!grouped.has(el)) revealOnEnter(el, [el]);
        });
      }
    </script>
  </body>
</html>
